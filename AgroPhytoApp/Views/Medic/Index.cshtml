@model List<AgroPhytoApp.Models.Medic>

@{
    ViewData["Title"] = "Medici";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="text-primary fw-bold">
            Echipa Medicală
        </h1>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Medic/Create"
               class="btn btn-success">
                + Adaugă Medic
            </a>
        }

    </div>

    <div class="row g-4">

        @foreach (var medic in Model)
        {
            <div class="col-md-4">

                <div class="card shadow-lg border-0 h-100">

                    <img src="@medic.ImagineUrl"
                         class="card-img-top"
                         style="height:300px; object-fit:cover;" />

                    <div class="card-body">

                        <h3>
                            @medic.Nume
                        </h3>

                        <p class="text-primary fw-bold">
                            @medic.Specializare
                        </p>

                        <p>
                            @medic.Descriere
                        </p>

                        <p>
                            <strong>Experiență:</strong>
                            @medic.Experienta ani
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a href="/Medic/Detalii/@medic.Id"
                           class="btn btn-primary w-100">
                            Detalii
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Medic/Edit/@medic.Id"
                               class="btn btn-warning w-100 mt-2">
                                Edit
                            </a>

                            <a href="/Medic/Delete/@medic.Id"
                               class="btn btn-danger w-100 mt-2">
                                Șterge
                            </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>