@{
    ViewData["Title"] = "Cabinete";
}

<div class="container mt-5">

    <h1 class="text-center text-primary fw-bold mb-5">
        Cabinetele Clinicii
    </h1>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow-lg border-0 h-100">

                <img src="https://images.unsplash.com/photo-1587351021759-3e566b6af7cc?w=800"
                     class="card-img-top"
                     style="height:250px; object-fit:cover;" />

                <div class="card-body">

                    <h3 class="text-primary">
                        Cabinet Cardiologie
                    </h3>

                    <p>
                        Număr cabinet: 101
                    </p>

                    <p>
                        Dotări:
                    </p>

                    <ul>
                        <li>EKG</li>
                        <li>Ecograf</li>
                        <li>Monitor cardiac</li>
                    </ul>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-lg border-0 h-100">

                <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?w=800"
                     class="card-img-top"
                     style="height:250px; object-fit:cover;" />

                <div class="card-body">

                    <h3 class="text-success">
                        Cabinet Pediatrie
                    </h3>

                    <p>
                        Număr cabinet: 202
                    </p>

                    <p>
                        Dotări:
                    </p>

                    <ul>
                        <li>Pat pediatric</li>
                        <li>Monitor funcții vitale</li>
                        <li>Trusă urgență</li>
                    </ul>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-lg border-0 h-100">

                <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800"
                     class="card-img-top"
                     style="height:250px; object-fit:cover;" />

                <div class="card-body">

                    <h3 class="text-danger">
                        Cabinet Neurologie
                    </h3>

                    <p>
                        Număr cabinet: 303
                    </p>

                    <p>
                        Dotări:
                    </p>

                    <ul>
                        <li>RMN</li>
                        <li>EEG</li>
                        <li>Sistem diagnostic neurologic</li>
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>