@{
    ViewData["Title"] = "Medici";
}

<div class="container mt-5">

    <h1 class="text-center text-primary fw-bold mb-5">
        Echipa Medicală
    </h1>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card border-0 shadow-lg h-100">

                <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=800"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;" />

                <div class="card-body text-center">

                    <h3>
                        Dr. Andrei Popescu
                    </h3>

                    <p class="text-primary fw-bold">
                        Cardiologie
                    </p>

                    <p class="text-muted">
                        Specialist în cardiologie cu experiență de peste 10 ani.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-lg h-100">

                <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=800"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;" />

                <div class="card-body text-center">

                    <h3>
                        Dr. Maria Ionescu
                    </h3>

                    <p class="text-success fw-bold">
                        Pediatrie
                    </p>

                    <p class="text-muted">
                        Medic pediatru dedicat îngrijirii copiilor.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-lg h-100">

                <img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=800"
                     class="card-img-top"
                     style="height:300px; object-fit:cover;" />

                <div class="card-body text-center">

                    <h3>
                        Dr. Elena Georgescu
                    </h3>

                    <p class="text-danger fw-bold">
                        Neurologie
                    </p>

                    <p class="text-muted">
                        Specialist neurolog cu experiență clinică avansată.
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>