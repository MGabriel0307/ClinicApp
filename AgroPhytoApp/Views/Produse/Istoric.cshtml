@{
    ViewData["Title"] = "Istoric Medical";
}

<div class="container mt-5">

    <h1 class="text-center text-primary fw-bold mb-5">
        Istoric Medical Pacienți
    </h1>

    <div class="card shadow-lg border-0 mb-4">

        <div class="card-body">

            <h3 class="text-primary">
                Pacient: Ion Popescu
            </h3>

            <hr />

            <p>
                <strong>Diagnostic:</strong>
                Hipertensiune arterială
            </p>

            <p>
                <strong>Rețetă:</strong>
                Prestarium, Aspenter
            </p>

            <p>
                <strong>Observații:</strong>
                Pacient stabil. Reevaluare peste 30 zile.
            </p>

        </div>

    </div>

    <div class="card shadow-lg border-0 mb-4">

        <div class="card-body">

            <h3 class="text-success">
                Pacient: Maria Ionescu
            </h3>

            <hr />

            <p>
                <strong>Diagnostic:</strong>
                Alergie sezonieră
            </p>

            <p>
                <strong>Rețetă:</strong>
                Aerius, vitamina C
            </p>

            <p>
                <strong>Observații:</strong>
                Necesită control peste 14 zile.
            </p>

        </div>

    </div>

    <div class="card shadow-lg border-0">

        <div class="card-body">

            <h3 class="text-danger">
                Pacient: Elena Georgescu
            </h3>

            <hr />

            <p>
                <strong>Diagnostic:</strong>
                Migrenă cronică
            </p>

            <p>
                <strong>Rețetă:</strong>
                Ibuprofen, Sumatriptan
            </p>

            <p>
                <strong>Observații:</strong>
                Se recomandă investigații neurologice suplimentare.
            </p>

        </div>

    </div>

</div>