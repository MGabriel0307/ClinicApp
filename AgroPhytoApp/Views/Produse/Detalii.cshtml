@model AgroPhytoApp.Models.Produs

@{
    ViewData["Title"] = "Detalii Programare";
}

<div class="container mt-5">

    <div class="row">

        <div class="col-md-5">

            <img src="@(string.IsNullOrEmpty(Model.ImagineUrl)
                                 ? "https://images.unsplash.com/photo-1584982751601-97dcc096659c?w=800"
                                 : Model.ImagineUrl)"
                 class="img-fluid rounded shadow-lg" />

        </div>

        <div class="col-md-7">

            <h1 class="text-primary fw-bold">
                @Model.Nume
            </h1>

            <hr />

            <h3 class="text-success">
                Taxă Consultație:
                @Model.Pret RON
            </h3>

            <p class="mt-4">
                <strong>Observații:</strong>
            </p>

            <p class="text-muted">
                @Model.Descriere
            </p>

            <p class="mt-4">
                <strong>Specializare:</strong>
                @Model.Categorie
            </p>

            <a href="/Produse/Cos?numeProdus=@Model.Nume"
               class="btn btn-primary btn-lg mt-4">

                Programează Consultația

            </a>

        </div>

    </div>

</div>