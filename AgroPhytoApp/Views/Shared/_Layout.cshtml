@using Microsoft.AspNetCore.Identity
@using AgroPhytoApp.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicApp</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <style>

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fa;
        }

        .navbar {
            background-color: #0d6efd !important;
        }

        .navbar-brand,
        .nav-link {
            color: white !important;
        }

            .nav-link:hover {
                color: #cfe2ff !important;
                transition: 0.3s;
            }

        .footer {
            background-color: #212529;
            color: white;
            padding: 20px 0;
            margin-top: 50px;
        }

        .user-profile-box {
            border-left: 1px solid #6ea8fe;
            padding-left: 15px;
        }

        .profile-image {
            width: 40px;
            height: 40px;
            object-fit: cover;
        }

    </style>

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">

            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Produse"
                   asp-action="Index">

                    🏥 CLINIC APP

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Produse"
                               asp-action="Index">

                                Acasă

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Produse"
                               asp-action="Catalog">

                                Programări

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Medic"
                               asp-action="Index">

                                Medici

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Produse"
                               asp-action="Contact">

                                Cabinete

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Produse"
                               asp-action="Istoric">

                                Istoric Medical

                            </a>

                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">

                                <a class="nav-link text-warning fw-bold"
                                   asp-controller="Produse"
                                   asp-action="Create">

                                    + Adaugă Programare

                                </a>

                            </li>
                        }

                    </ul>

                    <div class="navbar-nav user-profile-box text-light align-items-center">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);

                            <img src="@currentUser?.ProfileImageUrl"
                                 alt="Profil"
                                 class="rounded-circle me-2 border border-light profile-image" />

                            <small class="me-3">

                                <strong>@currentUser?.Email</strong>

                            </small>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="btn btn-sm btn-outline-light">

                                Logout

                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-sm btn-outline-light me-2">

                                Login

                            </a>

                            <a asp-controller="Account"
                               asp-action="Register"
                               class="btn btn-sm btn-success">

                                Register

                            </a>
                        }

                    </div>

                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-4">

        <main role="main" class="pb-5">

            @RenderBody()

        </main>

    </div>

    <footer class="footer text-center">

        <div class="container">

            <span>

                &copy; 2025 - ClinicApp - Platformă Web pentru Gestionarea Clinicii Medicale

            </span>

        </div>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>